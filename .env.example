# ─── POPUP Waitlist Site ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# These MUST match the main POPUP-master app — both projects share the same
# Supabase project so all waitlist submissions are instantly visible to the app.

# Supabase (from https://supabase.com/dashboard → your project → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# WalletConnect (from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Optional: RPC endpoint overrides (public endpoints used if not set)
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
